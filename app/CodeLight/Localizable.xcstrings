          }
        }
      }
    },
    "privacy_third_party_body": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "CodeLight does not use any analytics, tracking, or advertising services. No data is shared with third parties."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "CodeLight 不使用任何统计分析、跟踪或广告服务。不会向任何第三方共享数据。"
