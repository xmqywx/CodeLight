    "privacy_overview" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Overview"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "概述"
          }
        }
      }
    },
    "privacy_overview_body" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "CodeLight is an open-source application that syncs Claude Code sessions between your Mac and iPhone. Your privacy is important to us."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "CodeLight 是一款开源应用，用于在你的 Mac 与 iPhone 之间同步 Claude Code 会话。我们重视你的隐私。"
          }
        }
      }
    },
    "privacy_policy" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
