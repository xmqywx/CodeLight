    "privacy_camera": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Camera Usage"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "相机使用"
          }
        }
      }
    },
    "privacy_camera_body": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "CodeLight uses your device's camera solely for scanning QR codes during the device pairing process. No images or video are stored or transmitted."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "CodeLight 仅在设备配对流程中使用相机扫描二维码，不保存或传输任何图片或视频。"
          }
        }
      }
    },
    "privacy_contact": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Contact"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "联系方式"
          }
        }
      }
    },
    "privacy_contact_body": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Questions about this privacy policy can be sent to xmqywx@gmail.com or filed on GitHub Issues at https://github.com/xmqywx/CodeLight/issues."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "关于隐私政策的问题可发送至 xmqywx@gmail.com，或在 GitHub Issues 提交：https://github.com/xmqywx/CodeLight/issues。"
          }
        }
      }
    },
    "privacy_data_collection": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Data Collection"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "数据收集"
          }
        }
      }
    },
    "privacy_data_collection_body": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "CodeLight does not collect, store, or transmit any personal data to third parties. No analytics, no tracking, no advertising."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "CodeLight 不会收集、存储或向任何第三方传输个人数据。没有统计分析，没有跟踪，没有广告。"
          }
        }
      }
    },
    "privacy_data_storage": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Data Storage"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "数据存储"
          }
        }
      }
    },
    "privacy_data_storage_body": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Session data is stored on the CodeLight Server you connect to (self-hosted or public). You control where your data lives. Authentication keys are stored securely in your device's Keychain. Server URLs and connection settings are stored locally on your device."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "会话数据存储在你连接的 CodeLight 服务器上（自托管或公共）。你掌控数据的去向。认证密钥安全地保存在设备的钥匙串中。服务器地址和连接设置只保存在本机。"
          }
        }
      }
    },
    "privacy_encryption": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "End-to-End Encryption"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "端到端加密"
          }
        }
      }
    },
    "privacy_encryption_body": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Messages between your Mac and iPhone are designed to be end-to-end encrypted. The CodeLight Server acts as a zero-knowledge relay — it stores encrypted data without the ability to read it."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "你的 Mac 和 iPhone 之间的消息采用端到端加密设计。CodeLight 服务器作为零知识中继——它存储加密数据但无法读取内容。"
          }
        }
      }
    },
    "privacy_last_updated": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Last updated: April 7, 2026"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "最后更新：2026 年 4 月 7 日"
          }
        }
      }
    },
    "privacy_open_source": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Open Source"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "开源"
          }
        }
      }
    },
    "privacy_open_source_body": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "CodeLight is open source. You can review the complete source code at:"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "CodeLight 是开源项目，你可以在下面的地址查看完整源代码："
          }
        }
      }
    },
    "privacy_overview": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Overview"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "概述"
          }
        }
      }
    },
    "privacy_overview_body": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "CodeLight is an open-source application that syncs Claude Code sessions between your Mac and iPhone. Your privacy is important to us."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "CodeLight 是一款开源应用，用于在你的 Mac 与 iPhone 之间同步 Claude Code 会话。我们重视你的隐私。"
          }
        }
      }
    },
    "privacy_policy": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Privacy Policy"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "隐私政策"
          }
        }
      }
    },
    "privacy_push": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Push Notifications"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "推送通知"
          }
        }
      }
    },
    "privacy_push_body": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "If enabled, push notifications are delivered via Apple Push Notification Service (APNs). Device tokens are stored on the CodeLight Server you are connected to and are not shared with anyone else."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "如果启用，推送通知通过 Apple 推送通知服务（APNs）发送。设备令牌保存在你连接的 CodeLight 服务器上，不会与其他任何人共享。"
          }
        }
      }
    },
    "privacy_third_party": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Third-Party Services"
          }
        },
        "zh-Hans": {
