    "privacy_camera_body" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "CodeLight uses your device's camera solely for scanning QR codes during the device pairing process. No images or video are stored or transmitted."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "CodeLight 仅在设备配对流程中使用相机扫描二维码，不保存或传输任何图片或视频。"
          }
        }
      }
    },
    "privacy_contact" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Contact"
          }
        },
        "zh-Hans" : {
